NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Notificaciones por WhatsApp/SMS — ver docs/sql/notificaciones.sql
# Genera NOTIFICACIONES_WEBHOOK_SECRET tú mismo (cualquier string largo y
# aleatorio) y configura el MISMO valor en Supabase con:
#   alter database postgres set app.notificaciones_webhook_secret = '...';
NOTIFICACIONES_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de WhatsApp Business aprobado en Twilio, ej. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# Número de Twilio para SMS, ej. +14155238886
TWILIO_SMS_FROM=
