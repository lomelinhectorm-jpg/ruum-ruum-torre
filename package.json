{
  "name": "ruum-ruum-admin",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "quality": "npm run lint && npm run typecheck && npm run build",
    "audit": "npm audit --audit-level=moderate",
    "test:rls:anon": "node --env-file=.env.local scripts/rls-readonly.mjs",
    "test:rls": "node --env-file=.env.local --env-file=.env.rls.local scripts/rls-readonly.mjs --require-roles",
    "test:contract": "node scripts/check-platform-contract.mjs",
    "test:contract:live": "node --env-file=.env.local scripts/check-platform-contract.mjs --live"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "clsx": "^2.1.1",
    "next": "^16.2.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  }
}
